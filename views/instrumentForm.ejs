<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <h1>
        <%= title %>
    </h1>

    <form action="<%= instrument ? '/instruments/' + instrument.id + '/update' : '/instruments' %>" method="POST">

        <div>
            <label>Instrument Model Name:</label><br>
            <input type="text" name="name" value="<%= instrument ? instrument.name : '' %>" required />
        </div>
        <br>

        <div>
            <label>Brand/Manufacturer:</label><br>
            <select name="brand_id" required>
                <% brands.forEach(brand=> { %>
                    <option value="<%= brand.id %>" <%=instrument && instrument.brand_id===brand.id ? 'selected' : '' %>
                        >
                        <%= brand.name %>
                    </option>
                    <% }) %>
            </select>
        </div>
        <br>

        <div>
            <label>Instrument Category:</label><br>
            <select name="category_id" required>
                <% categories.forEach(cat=> { %>
                    <option value="<%= cat.id %>" <%=instrument && instrument.category_id===cat.id ? 'selected' : '' %>>
                        <%= cat.name %>
                    </option>
                    <% }) %>
            </select>
        </div>
        <br>

        <div>
            <label>Price (KES):</label><br>
            <input type="number" step="0.01" name="price" value="<%= instrument ? instrument.price : '' %>" required />
        </div>
        <br>

        <div>
            <label>Stock Quantity:</label><br>
            <input type="number" name="stock_quantity" value="<%= instrument ? instrument.stock_quantity : '' %>"
                required />
        </div>
        <br>

        <div>
            <label>Specification Details:</label><br>
            <textarea name="description"><%= instrument ? instrument.description : '' %></textarea>
        </div>
        <br>

        <button type="submit">Save Instrument Information</button>
    </form>

    <br>
    <a href="/categories">Cancel and return</a>
</body>

</html>