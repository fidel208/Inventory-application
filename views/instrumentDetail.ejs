<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>
        <%= instrument.name %>
    </title>
</head>

<body>
    <a href="/categories/<%= instrument.category_id %>">⬅Back to <%= instrument.category_name %></a>
    <h1>
        <%= instrument.brand_name %>
            <%= instrument.name %>
    </h1>
    <p><strong>Family Group:</strong>
        <%= instrument.category_name %>
    </p>
    <p><strong>Description:</strong>
        <%= instrument.description %>
    </p>
    <h3>Price: KES <%= instrument.price %>
    </h3>
    <h3>In Stock: <%= instrument.stock_quantity %> units</h3>

    <hr />
    <a href="/instruments/<%= instrument.id %>/edit">Edit Instrument Details</a>
    <br><br>
    <form action="/instruments/<%= instrument.id %>/delete" method="POST">
        <button type="submit"
            onclick="return confirm('Are you sure you want to remove this piece from stock inventory?')"
            style="color: red;">Remove Item</button>
    </form>
</body>

</html>