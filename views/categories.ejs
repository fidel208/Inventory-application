<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <h1>Musical Instruments Dashboard</h1>
    <hr />
    <a href="/categories/new">Add New Category</a> |
    <a href="/instruments/new">Add New Instrument</a>

    <h2>Instrument Families</h2>
    <ul>
        <% categories.forEach(cat=> { %>
            <li>
                <strong><a href="/categories/<%= cat.id %>">
                        <%= cat.name %>
                    </a></strong>
                - <%= cat.description %>
            </li>
            <% }) %>
    </ul>
</body>

</html>